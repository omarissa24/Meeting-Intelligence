# Service
ENVIRONMENT=development
CORS_ALLOW_ORIGINS=["http://localhost:1420"]
# INFO is the right default for normal use. Switch to DEBUG to see per-chunk
# (`transcript.chunk_recv`) and per-event (`transcript.event_emit ... latency_ms=…`)
# lines while diagnosing the live transcript pipeline.
LOG_LEVEL=INFO

# Data
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/meeting_intelligence
REDIS_URL=redis://localhost:6379/0

# Object storage (S3 / R2)
S3_ENDPOINT_URL=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=

# External providers
# STT provider selection. `echo` routes through the in-memory test double
# (default; no key needed). `deepgram` requires DEEPGRAM_API_KEY and routes
# through DeepgramNovaSTT for real transcription.
STT_PROVIDER=echo
DEEPGRAM_API_KEY=
ANTHROPIC_API_KEY=

# Auth
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
