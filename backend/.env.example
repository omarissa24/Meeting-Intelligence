# Service
ENVIRONMENT=development
CORS_ALLOW_ORIGINS=["http://localhost:1420"]
# INFO is the right default for normal use. Switch to DEBUG to see per-chunk
# (`transcript.chunk_recv`) and per-event (`transcript.event_emit ... latency_ms=…`)
# lines while diagnosing the live transcript pipeline.
LOG_LEVEL=INFO

# Data
# Connect as `app_user` (provisioned by infra/init-app-user.sql on first
# `docker compose up postgres`). Never set this to `postgres:…` — superusers
# bypass RLS unconditionally, and the backend's startup check
# (assert_not_bypassing_rls) will refuse to come up. See infra/README.md →
# Application role for the why and the manual recipe for existing volumes.
DATABASE_URL=postgresql+psycopg://app_user:app_dev_password@localhost:5432/meeting_intelligence
REDIS_URL=redis://localhost:6379/0

# Object storage (S3 / R2)
S3_ENDPOINT_URL=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=

# External providers
# STT provider selection. `echo` routes through the in-memory test double
# (default; no key needed). `deepgram` requires DEEPGRAM_API_KEY and routes
# through DeepgramNovaSTT for real transcription.
STT_PROVIDER=echo
DEEPGRAM_API_KEY=
ANTHROPIC_API_KEY=

# Auth — WorkOS AuthKit (https://dashboard.workos.com)
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
# Where AuthKit redirects after a successful sign-in. The desktop is
# configured to catch this scheme via tauri-plugin-deep-link; the URI
# must also be registered in the WorkOS dashboard under
# Redirects → Sign-in callback.
#
# `tauri:dev` does NOT register a custom URI scheme on macOS (the
# binary isn't bundled), so for local dev swap this to the loopback
# URL below. The desktop's debug build spawns a one-shot HTTP
# listener on 127.0.0.1:53682 before opening the browser; AuthKit's
# redirect lands on it directly (no React, no Tauri IPC) and the
# server runs the same code-exchange + keychain-store + emit pipeline
# as the deep-link path. Register both URIs in the WorkOS dashboard
# so prod-bundled builds keep using the deep-link scheme.
#   WORKOS_REDIRECT_URI=http://localhost:53682/callback
WORKOS_REDIRECT_URI=meeting-intelligence://auth/callback
# Leave unset to derive from WORKOS_CLIENT_ID. AuthKit access tokens carry
# `iss = https://api.workos.com/user_management/<client_id>`; only set this
# explicitly if WorkOS publishes a new issuer convention.
# WORKOS_JWT_ISSUER=
# Dev-only JWT signing key. Mints HS256 tokens via POST /auth/dev-token
# so integration tests + curl smoke runs don't have to drive AuthKit.
# 404s entirely when ENVIRONMENT=production. Generate with:
#   python -c 'import secrets; print(secrets.token_urlsafe(48))'
DEV_JWT_SIGNING_KEY=
