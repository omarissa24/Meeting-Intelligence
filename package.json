{
  "name": "meeting-intelligence",
  "private": true,
  "version": "0.0.0",
  "description": "Meeting Intelligence — cross-platform desktop app for capture, transcription, and LLM-summarised meeting intelligence.",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "concurrently --names api,app --prefix-colors blue,magenta --kill-others-on-fail \"pnpm dev:api\" \"pnpm dev:app\"",
    "dev:web": "pnpm --filter @meeting-intelligence/web dev",
    "dev:api": "cd backend && uv run uvicorn meeting_intelligence.main:app --reload --port 8000",
    "dev:app": "pnpm --filter @meeting-intelligence/desktop tauri:dev",
    "tauri:dev": "pnpm --filter @meeting-intelligence/desktop tauri:dev",
    "replay": "cd backend && uv run python scripts/replay_audio.py",
    "fixture": "bash scripts/make-fixture-wav.sh",
    "icons": "bash scripts/make-tauri-icons.sh",
    "test:api": "cd backend && uv run pytest",
    "test:ui": "pnpm --filter @meeting-intelligence/desktop test",
    "test": "pnpm test:api && pnpm test:ui",
    "build": "pnpm -r --filter \"./apps/*\" --filter \"./packages/*\" build",
    "typecheck": "pnpm -r --filter \"./apps/*\" --filter \"./packages/*\" typecheck",
    "lint": "pnpm -r --filter \"./apps/*\" --filter \"./packages/*\" lint",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "concurrently": "^10.0.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "packageExtensions": {
      "lucide-react": {
        "peerDependencies": {
          "@types/react": "*"
        },
        "peerDependenciesMeta": {
          "@types/react": {
            "optional": true
          }
        }
      },
      "sonner": {
        "peerDependencies": {
          "@types/react": "*"
        },
        "peerDependenciesMeta": {
          "@types/react": {
            "optional": true
          }
        }
      }
    }
  }
}
