{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "marens",
  "version": "0.1.0",
  "identifier": "com.meeting-intelligence.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "marens",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "entitlements": "Entitlements.plist"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["meeting-intelligence"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNGMUUyOTg4REQ5QjM3OApSV1I0czltTm1PTHhBL200ZVNOTEVuek80SnFYWm9ieG5JRVhSSzV0NkZ2QWYvdGNXR2E5SVNXbgo=",
      "endpoints": [
        "https://meeting-intelligence-api.fly.dev/updates/{{target}}/{{arch}}/{{current_version}}"
      ]
    }
  }
}
