# Marketing / download site (apps/web)

# GitHub repository (owner/name) the download buttons resolve installers from.
# The site calls https://api.github.com/repos/$GITHUB_REPO/releases/latest at
# build/ISR time and links to the .dmg / .msi assets. Server-only (not exposed
# to the browser). Defaults to omarissa24/Meeting-Intelligence.
GITHUB_REPO=omarissa24/Meeting-Intelligence

# Public canonical URL of the deployed site. Used as metadataBase for OpenGraph
# / canonical tags. Set to the production domain in Vercel.
NEXT_PUBLIC_SITE_URL=https://meeting-intelligence-murex.vercel.app
